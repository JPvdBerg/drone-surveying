# Copy to ".env.local" (git-ignored) and fill in real values.
# Vite only exposes variables prefixed with VITE_ to client code, read them via
# import.meta.env.VITE_NAME. NEVER put server secrets here; this bundle is public.
#
# Example usage in code:
#   const endpoint = import.meta.env.VITE_FORMSPREE_ENDPOINT;
#   await fetch(endpoint, { method: 'POST', body: formData });

# Optional: Formspree (or similar) endpoint for a hosted contact-form handler.
VITE_FORMSPREE_ENDPOINT=

# Optional: analytics measurement ID (e.g. Google Analytics / Plausible domain).
VITE_ANALYTICS_ID=
